{
  "name": "@elizaos/plugin-keeperhub",
  "description": "KeeperHub workflow automation plugin for ElizaOS — wraps all KeeperHub MCP tools as agent actions",
  "version": "1.7.3-alpha.0",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "packageType": "plugin",
  "platform": "node",
  "license": "MIT",
  "author": "KeeperHub",
  "keywords": [
    "plugin",
    "elizaos",
    "keeperhub",
    "workflow",
    "automation",
    "web3",
    "defi",
    "smart-contracts"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "dependencies": {
    "@elizaos/core": "workspace:*",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "bun run build.ts",
    "build:watch": "bun run build.ts --watch",
    "dev": "elizaos dev",
    "start": "elizaos start",
    "test": "bun test",
    "format": "prettier --write ./src"
  },
  "publishConfig": {
    "access": "public"
  },
  "agentConfig": {
    "pluginType": "elizaos:plugin:1.0.0",
    "pluginParameters": {
      "KH_API_KEY": {
        "type": "string",
        "description": "KeeperHub organization API key (starts with kh_)"
      }
    }
  }
}
