{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist/browser",
    "declaration": true,
    "declarationMap": false,
    "emitDeclarationOnly": true,
    "baseUrl": ".",
    "paths": {
      "@elizaos/core": ["../core/dist/index.d.ts"],
      "@elizaos/core/browser": ["../core/dist/browser/index.d.ts"],
      "@elizaos/core/node": ["../core/dist/node/index.d.ts"],
      "@elizaos/core/*": ["../core/dist/*"]
    }
  },
  "include": [
    "src/index.browser.ts",
    "src/pglite/**/*.ts",
    "src/schema/**/*.ts",
    "src/stores/**/*.ts",
    "src/base.ts",
    "src/types.ts",
    "src/utils.ts",
    "src/utils.browser.ts",
    "src/migration-service.ts",
    "src/migrations.ts",
    "src/rls.ts",
    "src/runtime-migrator/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "src/**/__tests__/**", "src/**/*.test.ts", "src/**/*.spec.ts"]
}
